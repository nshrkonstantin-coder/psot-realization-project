{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Parse без файла — ошибка",
      "method": "POST",
      "path": "/",
      "body": {"action": "parse", "file_base64": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Файл не передан"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Status пустой список",
      "method": "POST",
      "path": "/",
      "body": {"action": "status", "track_ids": []},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Load datasets",
      "method": "POST",
      "path": "/",
      "body": {"action": "load_datasets"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}