{
  "tests": [
    {
      "name": "GET - статистика файлов",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"total": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST save_files - сохранить файлы",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "save_files",
        "files": [
          {"path": "backend/test/index.py", "content": "def handler(e, c): pass", "section": "backend"}
        ]
      },
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST generate - генерация Word",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}
